---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Maxwell Rutman" dark={true}>
  <section class="hero">
    <div class="hero__text">
      <h1 class="hero__name">Maxwell Rutman</h1>
      <p class="hero__subtitle">TRANSDISCIPLINARY DESIGN</p>
      <p class="hero__tagline">
        Future-friendly form, fantasy, and <a href="https://www.youtube.com/watch?v=huzYji2OAD4" class="tagline-link" id="funktion-link" target="_blank" rel="noopener noreferrer">funktion</a>
      </p>
    </div>

    <!-- Concentric-circles graphic — rebuilt as native SVG so it works everywhere -->
    <!-- Data extracted from the original Lottie JSON (900×645 canvas, 7 s loop) -->
    <div class="hero__graphic" aria-hidden="true">
      <svg viewBox="0 0 900 645" xmlns="http://www.w3.org/2000/svg">
        <!--
          Six solid circles stacked back-to-front.
          Because each circle is fully opaque and smaller than the one behind,
          only the outer *ring* of each colour shows through — creating the
          concentric-ring look without needing clip-paths or stroke math.
        -->
        <circle cx="452" cy="336.5" r="421"   fill="#808080"/>
        <circle cx="452" cy="336.5" r="363.5" fill="#535353"/>
        <circle cx="452" cy="336.5" r="310"   fill="#393939"/>
        <circle cx="452" cy="336.5" r="245.5" fill="#242424"/>
        <circle cx="452" cy="336.5" r="183.5" fill="#131313"/>
        <circle cx="452" cy="336.5" r="114"   fill="#0a0a0a"/>

        <!--
          Two visible floating dots (dot 3 & dot 6 from the Lottie layers).
          Keyframe positions are taken directly from the JSON position data.
          calcMode="spline" + keySplines reproduce the ease-in/ease-out bezier
          that the original animation uses.
        -->
        <circle r="7" fill="#d1d1d1">
          <animate attributeName="cx"
            values="316.5;144;316.5"
            dur="7s" repeatCount="indefinite"
            calcMode="spline" keyTimes="0;0.5;1"
            keySplines="0.448 0.004 0.467 1;0.467 0 0.457 0.995"/>
          <animate attributeName="cy"
            values="433.5;481.5;433.5"
            dur="7s" repeatCount="indefinite"
            calcMode="spline" keyTimes="0;0.5;1"
            keySplines="0.448 0.004 0.467 1;0.467 0 0.457 0.995"/>
        </circle>

        <circle r="6" fill="#f5f5f5">
          <animate attributeName="cx"
            values="773.5;475;773.5"
            dur="7s" repeatCount="indefinite"
            calcMode="spline" keyTimes="0;0.5;1"
            keySplines="0.448 0.004 0.467 1;0.467 0 0.457 0.995"/>
          <animate attributeName="cy"
            values="322.5;351.5;322.5"
            dur="7s" repeatCount="indefinite"
            calcMode="spline" keyTimes="0;0.5;1"
            keySplines="0.448 0.004 0.467 1;0.467 0 0.457 0.995"/>
        </circle>
      </svg>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 100vh;
    padding: 0 8vw;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
  }

  .hero__name {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.55);
    margin-top: -4px;
  }

  .hero__tagline {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 20px;
  }

  .tagline-link {
    /* text-fill transparent lets the animated background show through the letterforms */
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-decoration: none;
    /* background-image is set each frame by the JS animation loop */
  }

  .hero__graphic {
    width: clamp(280px, 40vw, 480px);
    flex-shrink: 0;
  }

  .hero__graphic svg {
    width: 100%;
    height: auto;
  }

  .hero__graphic svg {
    display: block;
    overflow: visible;
  }
</style>

<script>
  const link = document.getElementById('funktion-link') as HTMLElement;

  // Current hue — starts at 0° (red) and wraps at 360°
  let hue = 0;

  function animate() {
    // Advance 0.6° per frame → ~36°/sec at 60fps: slow, smooth, readable
    hue = (hue + 0.6) % 360;

    // Build two gradient stops offset by 80° so the word always spans
    // two neighbouring rainbow hues (e.g. red→orange, blue→purple).
    // Setting backgroundImage directly each frame is the most reliable
    // cross-browser way to animate a gradient — CSS custom properties
    // inside hsl() aren't consistently supported in gradients yet.
    const h1 = hue;
    const h2 = (hue + 80) % 360;
    link.style.backgroundImage =
      `linear-gradient(90deg, hsl(${h1},90%,70%), hsl(${h2},90%,70%))`;


    // requestAnimationFrame: runs at the display's refresh rate (usually
    // 60fps), automatically pauses when the tab is hidden (good for battery),
    // and is frame-synced so there's no tearing or stuttering.
    requestAnimationFrame(animate);
  }

  animate();
</script>
