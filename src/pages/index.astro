---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Maxwell Rutman" dark={true}>
  <section class="hero">
    <div class="hero__text">
      <h1 class="hero__name">Maxwell Rutman</h1>
      <p class="hero__subtitle">TRANSDISCIPLINARY DESIGN</p>
      <p class="hero__tagline">
        Future-friendly form, fantasy, and <a href={`${base}/sandbox`} class="tagline-link">funktion</a>
      </p>
    </div>

    <div class="hero__graphic" aria-hidden="true">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
        <!-- Concentric rings -->
        <circle cx="185" cy="200" r="180" fill="#2a2a2a" />
        <circle cx="185" cy="200" r="148" fill="#333333" />
        <circle cx="185" cy="200" r="118" fill="#3d3d3d" />
        <circle cx="185" cy="200" r="90"  fill="#454545" />
        <circle cx="185" cy="200" r="64"  fill="#4f4f4f" />
        <circle cx="185" cy="200" r="40"  fill="#1a1a1a" />
        <circle cx="185" cy="200" r="18"  fill="#0a0a0a" />
        <!-- Small satellite circle (dark) -->
        <circle cx="316" cy="170" r="28"  fill="#5a5a5a" />
        <!-- White accent circle -->
        <circle cx="330" cy="220" r="38"  fill="#e8e8e8" />
      </svg>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 100vh;
    padding: 0 8vw;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
  }

  .hero__name {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.55);
    margin-top: -4px;
  }

  .hero__tagline {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 20px;
  }

  .tagline-link {
    color: rgba(255, 255, 255, 0.6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    transition: color 0.2s, border-color 0.2s;
  }

  .tagline-link:hover {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .hero__graphic {
    width: clamp(280px, 40vw, 480px);
    flex-shrink: 0;
  }

  .hero__graphic svg {
    width: 100%;
    height: auto;
  }
</style>
