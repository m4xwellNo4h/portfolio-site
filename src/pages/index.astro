---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Maxwell Rutman" dark={true}>
  <section class="hero">
    <div class="hero__text">
      <h1 class="hero__name">Maxwell Rutman</h1>
      <p class="hero__subtitle">TRANSDISCIPLINARY DESIGN</p>
      <p class="hero__tagline">
        Future-friendly form, fantasy, and <a href="https://www.youtube.com/watch?v=huzYji2OAD4" class="tagline-link" id="funktion-link" target="_blank" rel="noopener noreferrer">funktion</a>
      </p>
    </div>

    <div class="hero__graphic" aria-hidden="true">
      <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
        <!-- Concentric rings -->
        <circle cx="185" cy="200" r="180" fill="#2a2a2a" />
        <circle cx="185" cy="200" r="148" fill="#333333" />
        <circle cx="185" cy="200" r="118" fill="#3d3d3d" />
        <circle cx="185" cy="200" r="90"  fill="#454545" />
        <circle cx="185" cy="200" r="64"  fill="#4f4f4f" />
        <circle cx="185" cy="200" r="40"  fill="#1a1a1a" />
        <circle cx="185" cy="200" r="18"  fill="#0a0a0a" />
        <!-- Small satellite circle (dark) -->
        <circle cx="316" cy="170" r="28"  fill="#5a5a5a" />
        <!-- White accent circle -->
        <circle cx="330" cy="220" r="38"  fill="#e8e8e8" />
      </svg>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 100vh;
    padding: 0 8vw;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
  }

  .hero__name {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.55);
    margin-top: -4px;
  }

  .hero__tagline {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 20px;
  }

  .tagline-link {
    /* text-fill transparent lets the animated background show through the letterforms */
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-decoration: underline;
    text-underline-offset: 3px;
    /* background-image is set each frame by the JS animation loop */
  }

  .hero__graphic {
    width: clamp(280px, 40vw, 480px);
    flex-shrink: 0;
  }

  .hero__graphic svg {
    width: 100%;
    height: auto;
  }
</style>

<script>
  const link = document.getElementById('funktion-link') as HTMLElement;

  // Current hue — starts at 0° (red) and wraps at 360°
  let hue = 0;

  function animate() {
    // Advance 0.6° per frame → ~36°/sec at 60fps: slow, smooth, readable
    hue = (hue + 0.6) % 360;

    // Build two gradient stops offset by 80° so the word always spans
    // two neighbouring rainbow hues (e.g. red→orange, blue→purple).
    // Setting backgroundImage directly each frame is the most reliable
    // cross-browser way to animate a gradient — CSS custom properties
    // inside hsl() aren't consistently supported in gradients yet.
    const h1 = hue;
    const h2 = (hue + 80) % 360;
    link.style.backgroundImage =
      `linear-gradient(90deg, hsl(${h1},90%,70%), hsl(${h2},90%,70%))`;

    // Keep the underline tint in sync with the leading gradient stop
    link.style.textDecorationColor = `hsl(${h1},90%,70%)`;

    // requestAnimationFrame: runs at the display's refresh rate (usually
    // 60fps), automatically pauses when the tab is hidden (good for battery),
    // and is frame-synced so there's no tearing or stuttering.
    requestAnimationFrame(animate);
  }

  animate();
</script>
