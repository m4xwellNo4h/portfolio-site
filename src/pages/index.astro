---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Maxwell Rutman" dark={true}>
  <section class="hero">
    <div class="hero__text">
      <h1 class="hero__name">Maxwell Rutman</h1>
      <p class="hero__subtitle">TRANSDISCIPLINARY DESIGN</p>
      <p class="hero__tagline">
        Future-friendly form, fantasy, and <a href="https://www.youtube.com/watch?v=huzYji2OAD4" class="tagline-link" id="funktion-link" target="_blank" rel="noopener noreferrer">funktion</a>
      </p>
    </div>

    <div class="hero__graphic" id="lottie-container" aria-hidden="true"></div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 100vh;
    padding: 0 8vw;
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
  }

  .hero__name {
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.55);
    margin-top: -4px;
  }

  .hero__tagline {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 20px;
  }

  .tagline-link {
    /* text-fill transparent lets the animated background show through the letterforms */
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-decoration: none;
    /* background-image is set each frame by the JS animation loop */
  }

  .hero__graphic {
    width: clamp(280px, 40vw, 480px);
    flex-shrink: 0;
  }

  .hero__graphic svg {
    width: 100%;
    height: auto;
  }

  #lottie-container svg {
    display: block;
  }
</style>

<script>
  import lottie from 'lottie-web';

  const base = import.meta.env.BASE_URL.replace(/\/$/, '');

  lottie.loadAnimation({
    container: document.getElementById('lottie-container')!,
    renderer: 'svg',
    loop: true,
    autoplay: true,
    path: `${base}/animations/circles.json`,
  });
</script>

<script>
  const link = document.getElementById('funktion-link') as HTMLElement;

  // Current hue — starts at 0° (red) and wraps at 360°
  let hue = 0;

  function animate() {
    // Advance 0.6° per frame → ~36°/sec at 60fps: slow, smooth, readable
    hue = (hue + 0.6) % 360;

    // Build two gradient stops offset by 80° so the word always spans
    // two neighbouring rainbow hues (e.g. red→orange, blue→purple).
    // Setting backgroundImage directly each frame is the most reliable
    // cross-browser way to animate a gradient — CSS custom properties
    // inside hsl() aren't consistently supported in gradients yet.
    const h1 = hue;
    const h2 = (hue + 80) % 360;
    link.style.backgroundImage =
      `linear-gradient(90deg, hsl(${h1},90%,70%), hsl(${h2},90%,70%))`;


    // requestAnimationFrame: runs at the display's refresh rate (usually
    // 60fps), automatically pauses when the tab is hidden (good for battery),
    // and is frame-synced so there's no tearing or stuttering.
    requestAnimationFrame(animate);
  }

  animate();
</script>
